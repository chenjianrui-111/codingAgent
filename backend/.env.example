APP_NAME=coding-agent
ENV=development
API_PREFIX=/api/v1

OCEANBASE_HOST=127.0.0.1
OCEANBASE_PORT=2881
OCEANBASE_USER=root@test
OCEANBASE_PASSWORD=
OCEANBASE_DATABASE=coding_agent

RUN_WORKSPACE=/Users/chenjianrui/vsCodeProjects/codingAgent
RUN_TEST_COMMAND=pytest -q
CONTEXT_REPO_NAME=codingAgent
CONTEXT_BRANCH_NAME=main
MEMORY_MAX_ITEMS_PER_SESSION=80
MEMORY_KEEP_RECENT_ITEMS=36
MEMORY_SUMMARY_BATCH_SIZE=16
MEMORY_CONTEXT_CHAR_BUDGET=5000
PROJECT_VECTOR_DIM=64
PROJECT_CONTEXT_MAX_ITEMS=12

# Auth / Tenant
AUTH_REQUIRED=true
AUTH_GOOGLE_VERIFY_MODE=tokeninfo
AUTH_GOOGLE_CLIENT_IDS=your-google-web-client-id.apps.googleusercontent.com

# Invite Email (resend | sendgrid | noop)
INVITE_ACCEPT_URL_BASE=http://127.0.0.1:5173
INVITE_EMAIL_ENABLED=false
INVITE_EMAIL_PROVIDER=noop
INVITE_EMAIL_REQUIRED=false
INVITE_EMAIL_FROM=noreply@example.com
INVITE_EMAIL_REPLY_TO=
INVITE_EMAIL_SUBJECT_PREFIX=[Coding Agent]
RESEND_API_KEY=
SENDGRID_API_KEY=
